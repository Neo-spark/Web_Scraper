# ============================================================
# Sampark Setu - Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/govcontacts

# Crawler settings
MAX_PAGES=1000
CONCURRENCY=12
REQUEST_DELAY=0.3
MAX_DEPTH=3

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change_this_to_a_strong_random_key

# Optional: Google Gemini for RAG (leave blank to skip)
GOOGLE_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/crawler.log
